# Copy to `.env` (often at the workspace root). It is gitignored.
# The server walks up from the process current directory to find `.env`, so `cargo run` from a
# subcrate directory still picks up a root `.env`. Override with `OLLAMA_CONTROLS_DOTENV=/path/.env`.

# HTTP gateway
OLLAMA_CONTROLS_BIND=127.0.0.1:3000

# Upstream Ollama (same convention as the `ollama` CLI)
OLLAMA_HOST=http://127.0.0.1:11434

# Optional: load a specific env file instead of `./.env`
# OLLAMA_CONTROLS_DOTENV=/absolute/path/to/.env

# --- API key authentication ---
# If `OLLAMA_CONTROLS_REQUIRE_API_KEY` is unset, auth turns on when
# `OLLAMA_CONTROLS_KEYSTORE_PASSPHRASE` is non-empty.
# Set to false/0/no/off to force auth off even if a passphrase is set.
OLLAMA_CONTROLS_REQUIRE_API_KEY=false

# Passphrase for the age-encrypted keystore (same as `ollama-api key-gen` uses).
# Leave empty to run the gateway without API keys (local dev only).
OLLAMA_CONTROLS_KEYSTORE_PASSPHRASE=

# Optional: path to `api-keys.age` (default: XDG config dir …/ollama-controls/api-keys.age)
# OLLAMA_CONTROLS_KEYSTORE=
